# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/artifacts
.next-server.pid

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local project notes with credentials
docs/*.local.md
start-*.log
dev-*.log

# Tymczasowe pliki migracji WP
wp-files-needed.txt
uploads-needed.txt
all-wp-files.txt
wp-content-needed.tar.gz

# Obrazy WP — śledzone przez Git LFS (patrz .gitattributes)
# Pliki CSS/JS z /public/wp-content/plugins/ i /themes/ są w Git normalnie
# Duże pliki binarne (zdjęcia produktów, uploads) przez LFS
public/wp-content/uploads/2025/**
public/wp-content/uploads/2026/**
